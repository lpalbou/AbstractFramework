{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abstractframework.ai/schemas/install-manifest.schema.json",
  "title": "AbstractFramework install manifest",
  "type": "object",
  "required": [
    "schema_version",
    "minimum_installer_version",
    "framework",
    "source",
    "profiles",
    "python_packages",
    "npm_apps",
    "post_install",
    "security"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "minimum_installer_version": {
      "type": "string"
    },
    "framework": {
      "$ref": "#/$defs/package"
    },
    "source": {
      "type": "object",
      "required": ["repository", "release_profile"],
      "properties": {
        "repository": {"type": "string"},
        "release_profile": {"type": "string"}
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/profile"}
    },
    "python_packages": {
      "type": "array",
      "items": {"$ref": "#/$defs/package"}
    },
    "npm_apps": {
      "type": "array",
      "items": {"$ref": "#/$defs/npm_app"}
    },
    "post_install": {
      "type": "object"
    },
    "security": {
      "type": "object",
      "required": ["secrets_in_manifest", "native_artifacts_signed", "notes"],
      "properties": {
        "secrets_in_manifest": {"type": "boolean"},
        "native_artifacts_signed": {"type": "boolean"},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "required": ["id", "version", "registry"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "distribution": {"type": "string"},
        "version": {"type": "string"},
        "registry": {"type": "string"},
        "python_requires": {"type": "string"}
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": [
        "id",
        "name",
        "summary",
        "pip_requirements",
        "local_inference",
        "platforms",
        "prerequisites",
        "best_for",
        "excludes"
      ],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "summary": {"type": "string"},
        "pip_requirements": {
          "type": "array",
          "items": {"type": "string"}
        },
        "local_inference": {"type": "boolean"},
        "platforms": {
          "type": "array",
          "items": {"type": "string"}
        },
        "prerequisites": {
          "type": "array",
          "items": {"type": "string"}
        },
        "best_for": {
          "type": "array",
          "items": {"type": "string"}
        },
        "excludes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "npm_app": {
      "type": "object",
      "required": ["id", "package", "version", "registry", "command"],
      "properties": {
        "id": {"type": "string"},
        "package": {"type": "string"},
        "version": {"type": "string"},
        "registry": {"type": "string"},
        "command": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
