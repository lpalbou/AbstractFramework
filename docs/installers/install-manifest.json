{
  "framework": {
    "distribution": "abstractframework",
    "id": "abstractframework",
    "name": "AbstractFramework",
    "python_requires": ">=3.10",
    "registry": "pypi",
    "version": "0.1.10"
  },
  "minimum_installer_version": "0.1.0",
  "npm_apps": [
    {
      "command": "npx @abstractframework/flow",
      "id": "flow",
      "package": "@abstractframework/flow",
      "registry": "npm",
      "version": "0.3.19"
    },
    {
      "command": "npx @abstractframework/code",
      "id": "code",
      "package": "@abstractframework/code",
      "registry": "npm",
      "version": "0.3.9"
    },
    {
      "command": "npx @abstractframework/observer",
      "id": "observer",
      "package": "@abstractframework/observer",
      "registry": "npm",
      "version": "0.1.11"
    }
  ],
  "post_install": {
    "core_config": [
      "abstractcore",
      "--config"
    ],
    "doctor": [
      "abstractframework",
      "doctor"
    ],
    "gateway_flow": {
      "flow": [
        "npx",
        "@abstractframework/flow"
      ],
      "gateway": [
        "abstractgateway",
        "serve"
      ]
    }
  },
  "profiles": [
    {
      "best_for": [
        "cloud APIs",
        "LM Studio, Ollama, vLLM, llama.cpp, or other endpoint servers",
        "lowest-friction install"
      ],
      "excludes": [
        "local MLX engines",
        "local CUDA/ROCm engines"
      ],
      "id": "light",
      "local_inference": false,
      "name": "Light",
      "pip_requirements": [
        "abstractframework==0.1.10"
      ],
      "platforms": [
        "macos",
        "linux",
        "windows"
      ],
      "prerequisites": [
        "python>=3.10",
        "network"
      ],
      "summary": "Remote-first install. Full framework functionality is available through remote or OpenAI-compatible endpoints; no local MLX, CUDA, Diffusers, or model-runtime stacks are installed by this profile."
    },
    {
      "best_for": [
        "Mac users who want local Apple Silicon inferencers"
      ],
      "excludes": [
        "CUDA/ROCm engines"
      ],
      "id": "apple",
      "local_inference": true,
      "name": "Apple",
      "pip_requirements": [
        "abstractframework[apple]==0.1.10"
      ],
      "platforms": [
        "macos"
      ],
      "prerequisites": [
        "python>=3.10",
        "apple-silicon",
        "network"
      ],
      "summary": "Native Apple Silicon profile. Adds local MLX/Metal-capable stacks on top of the same framework interfaces and endpoint providers."
    },
    {
      "best_for": [
        "workstations or servers with supported discrete GPUs"
      ],
      "excludes": [
        "Apple MLX-only engines"
      ],
      "id": "gpu",
      "local_inference": true,
      "name": "GPU",
      "pip_requirements": [
        "abstractframework[gpu]==0.1.10"
      ],
      "platforms": [
        "linux",
        "windows"
      ],
      "prerequisites": [
        "python>=3.10",
        "gpu-driver",
        "network"
      ],
      "summary": "Native GPU profile. Adds CUDA/ROCm-oriented local stacks on top of the same framework interfaces and endpoint providers."
    }
  ],
  "python_packages": [
    {
      "distribution": "abstractcore",
      "id": "abstractcore",
      "registry": "pypi",
      "version": "2.13.38"
    },
    {
      "distribution": "AbstractRuntime",
      "id": "abstractruntime",
      "registry": "pypi",
      "version": "0.4.29"
    },
    {
      "distribution": "abstractagent",
      "id": "abstractagent",
      "registry": "pypi",
      "version": "0.3.12"
    },
    {
      "distribution": "abstractcode",
      "id": "abstractcode",
      "registry": "pypi",
      "version": "0.3.9"
    },
    {
      "distribution": "abstractgateway",
      "id": "abstractgateway",
      "registry": "pypi",
      "version": "0.2.28"
    },
    {
      "distribution": "AbstractMemory",
      "id": "abstractmemory",
      "registry": "pypi",
      "version": "0.2.6"
    },
    {
      "distribution": "abstractsemantics",
      "id": "abstractsemantics",
      "registry": "pypi",
      "version": "0.0.4"
    },
    {
      "distribution": "abstractvoice",
      "id": "abstractvoice",
      "registry": "pypi",
      "version": "0.10.18"
    },
    {
      "distribution": "abstractvision",
      "id": "abstractvision",
      "registry": "pypi",
      "version": "0.3.26"
    },
    {
      "distribution": "abstractmusic",
      "id": "abstractmusic",
      "registry": "pypi",
      "version": "0.1.13"
    },
    {
      "distribution": "abstractassistant",
      "id": "abstractassistant",
      "registry": "pypi",
      "version": "0.4.10"
    }
  ],
  "schema_version": 1,
  "security": {
    "native_artifacts_signed": false,
    "notes": "Prototype manifest; production installer artifacts must add signatures.",
    "secrets_in_manifest": false
  },
  "source": {
    "release_profile": "abstractframework.RELEASE_VERSIONS",
    "repository": "https://github.com/lpalbou/AbstractFramework"
  }
}
