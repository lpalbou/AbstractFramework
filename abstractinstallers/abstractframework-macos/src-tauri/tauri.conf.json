{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AbstractFramework Installer",
  "version": "0.1.0",
  "identifier": "com.abstractframework.installer",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AbstractFramework Installer (macOS)",
        "width": 980,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
